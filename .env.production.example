# ──────────────────────────────────────────────────────────
# Smart ERP Next — Production Environment Variables
# Copy to .env.production:  cp .env.production.example .env.production
# ──────────────────────────────────────────────────────────

# ── Database ─────────────────────────────────────────────
DB_PASSWORD=change_me_in_production
DB_USER=smart_erp_prod
DB_PORT=5432

# ── API ──────────────────────────────────────────────────
API_PORT=3456
JWT_SECRET=change_me_in_production
JWT_EXPIRES_IN=7d
CORS_ORIGINS=http://localhost:3457
LOGIN_RATE_LIMIT=20

# ── Web ──────────────────────────────────────────────────
WEB_PORT=3457
NEXT_PUBLIC_API_URL=http://localhost:3456
NEXT_PUBLIC_SITE_URL=http://localhost:3457

# ── Image ────────────────────────────────────────────────
IMAGE_TAG=latest
