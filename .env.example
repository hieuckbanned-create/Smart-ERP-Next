# ─────────────────────────────────────────────────────────────────────────────
# Smart ERP Next — Environment Variables
# Copy this file to .env and fill in the values before running docker-compose
# ─────────────────────────────────────────────────────────────────────────────

# ── Database ──────────────────────────────────────────────────────────────────
DB_USER=smart_erp
DB_PASSWORD=change_me_strong_password   # REQUIRED — change this
DB_PORT=5432

# ── API ───────────────────────────────────────────────────────────────────────
API_PORT=3000
JWT_SECRET=change_me_min_32_chars_random_string   # REQUIRED — change this
JWT_EXPIRES_IN=7d

# Browser origins allowed to call the API.
# Local:  http://localhost:3457
# Remote: https://yourdomain.com
CORS_ORIGINS=http://localhost:3457

# ── Web ───────────────────────────────────────────────────────────────────────
WEB_PORT=3001

# URL of the API as seen from the user's browser (not internal Docker network)
# Local:  http://localhost:3456
# Remote: http://YOUR_SERVER_IP:3000  or  https://api.yourdomain.com
NEXT_PUBLIC_API_URL=http://localhost:3456

# Public web origin used for metadata, robots.txt and sitemap.xml
# Local:  http://localhost:3457
# Remote: https://yourdomain.com
NEXT_PUBLIC_SITE_URL=http://localhost:3457

# ── AI Forecast ───────────────────────────────────────────────────────────────
AI_FORECAST_PORT=8000
