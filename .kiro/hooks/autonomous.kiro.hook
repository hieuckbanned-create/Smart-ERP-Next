{
  "version": "1.0.0",
  "enabled": true,
  "name": "autonomous",
  "when": {
    "type": "agentStop"
  },
  "then": {
    "type": "askAgent",
    "prompt": "với tư duy của development owner. hãy tiếp tục phát triển Smart ERP Next vượt trội hơn ERPNext/Odoo/VietERP/KiotViet/Nhanhvn/Misa, đảm bảo native toàn bộ các nền tảng, cấu trúc kiểu packages/apps/shared có bản địa hóa luôn, cập nhật tài liệu liên quan, commit thông minh"
  }
}