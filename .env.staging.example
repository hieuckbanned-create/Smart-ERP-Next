# ──────────────────────────────────────────────────────────
# Smart ERP Next — Staging Environment Variables
# Copy to .env.staging:  cp .env.staging.example .env.staging
# ──────────────────────────────────────────────────────────

# ── Database ─────────────────────────────────────────────
DB_PASSWORD=change_me_in_staging
DB_USER=smart_erp_staging
DB_PORT=5432

# ── API ──────────────────────────────────────────────────
API_PORT=3456
JWT_SECRET=change_me_in_staging
JWT_EXPIRES_IN=7d
CORS_ORIGINS=http://localhost:3457
LOGIN_RATE_LIMIT=50

# ── Web ──────────────────────────────────────────────────
WEB_PORT=3457
NEXT_PUBLIC_API_URL=http://localhost:3456
NEXT_PUBLIC_SITE_URL=http://localhost:3457

# ── Image ────────────────────────────────────────────────
IMAGE_TAG=latest
