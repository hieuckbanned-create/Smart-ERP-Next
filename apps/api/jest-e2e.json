{
  "moduleFileExtensions": ["js", "json", "ts"],
  "rootDir": ".",
  "testEnvironment": "node",
  "testRegex": ".e2e-spec.ts$",
  "transform": {
    "^.+\\.(t|j)s$": "ts-jest"
  },
  "moduleNameMapper": {
    "^uuid$": "<rootDir>/test/uuid.mock.ts",
    "^@smart-erp/database(.*)$": "<rootDir>/../../packages/database/src$1",
    "^@smart-erp/i18n(.*)$": "<rootDir>/../../packages/i18n/src$1",
    "^@smart-erp/(.*)$": "<rootDir>/../../packages/$1/src/index.ts"
  }
}
