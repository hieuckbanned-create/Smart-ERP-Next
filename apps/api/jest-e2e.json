{
  "moduleFileExtensions": ["js", "json", "ts"],
  "rootDir": ".",
  "testEnvironment": "node",
  "testRegex": ".e2e-spec.ts$",
  "transform": {
    "^.+\\.(t|j)s$": "ts-jest"
  },
  "moduleNameMapper": {
    "^@smart-erp/database(.*)$": "<rootDir>/../../packages/database/src$1",
    "^@smart-erp/i18n(.*)$": "<rootDir>/../../packages/i18n/src$1"
  }
}