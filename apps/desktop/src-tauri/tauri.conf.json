{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Smart ERP Next",
  "version": "0.1.0",
  "identifier": "vn.smarterp.next",
  "build": {
    "beforeBuildCommand": "pnpm --filter @smart-erp/desktop build",
    "beforeDevCommand": "pnpm --filter @smart-erp/desktop dev",
    "devUrl": "http://localhost:1420",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "center": true,
        "fullscreen": false,
        "height": 800,
        "minHeight": 600,
        "minWidth": 1024,
        "resizable": true,
        "title": "Smart ERP Next",
        "width": 1280
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["nsis"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "windows": {
      "certificateThumbprint": null,
      "digestAlgorithm": "sha256",
      "timestampUrl": ""
    }
  }
}
